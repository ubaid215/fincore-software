// prisma/schema/expenses.prisma
// Domain: Expense Management

model Expense {
  id             String        @id @default(uuid())
  organizationId String  @map("organization_id")
  claimantId     String  @map("claimant_id")
  approverId     String?  @map("approver_id")
  title          String
  description    String?
  totalAmount    Decimal       @db.Decimal(19, 4)  @map("total_amount")
  currency       String        @default("PKR")
  status         ExpenseStatus @default(DRAFT)
  submittedAt    DateTime?  @map("submitted_at")
  approvedAt     DateTime?  @map("approved_at")
  rejectedAt     DateTime?  @map("rejected_at")
  rejectionNote  String?  @map("rejection_note")
  postedToGLAt   DateTime?  @map("posted_to_gl_at")
  costCenterId   String?  @map("cost_center_id")
  createdAt      DateTime      @default(now())  @map("created_at")
  updatedAt      DateTime      @updatedAt  @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  claimant     User         @relation("ExpenseClaimer", fields: [claimantId], references: [id])
  approver     User?        @relation("ExpenseApprover", fields: [approverId], references: [id])
  lines        ExpenseLine[]
  receipts     Receipt[]
  costCenter   CostCenter? @relation(fields: [costCenterId], references: [id])

  @@index([organizationId, status])
  @@index([organizationId, claimantId])
}

model ExpenseLine {
  id          String  @id @default(uuid())
  expenseId   String  @map("expense_id")
  accountId   String  @map("account_id")
  description String
  amount      Decimal @db.Decimal(19, 4)
  category    String

  expense Expense @relation(fields: [expenseId], references: [id], onDelete: Cascade)
  account Account @relation(fields: [accountId], references: [id])

  @@index([expenseId])
}

model Receipt {
  id        String   @id @default(uuid())
  expenseId String  @map("expense_id")
  fileName  String  @map("file_name")
  s3Key     String
  mimeType  String  @map("mime_type")
  sizeBytes Int  @map("size_bytes")
  createdAt DateTime @default(now())  @map("created_at")

  expense Expense @relation(fields: [expenseId], references: [id], onDelete: Cascade)

  @@index([expenseId])
}

model CostCenter {
  id             String   @id @default(uuid())
  organizationId String  @map("organization_id")
  code           String
  name           String
  parentId       String?  @map("parent_id")
  managerId      String?  @map("manager_id")
  budget         Decimal  @db.Decimal(19, 4)
  actual         Decimal  @default(0) @db.Decimal(19, 4)
  isActive       Boolean  @default(true)  @map("is_active")
  createdAt      DateTime @default(now())  @map("created_at")
  updatedAt      DateTime @updatedAt  @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  parent       CostCenter?  @relation("CostCenterHierarchy", fields: [parentId], references: [id])
  children     CostCenter[] @relation("CostCenterHierarchy")
  expenses     Expense[]

  @@unique([organizationId, code])
  @@index([organizationId, parentId])
}

enum ExpenseStatus {
  DRAFT
  SUBMITTED
  MANAGER_APPROVED
  FINANCE_APPROVED
  POSTED
  REJECTED
}