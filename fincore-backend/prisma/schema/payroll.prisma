// prisma/schema/payroll.prisma
// Domain: Payroll Management

model Employee {
  id             String   @id @default(uuid())
  organizationId String  @map("organization_id")
  employeeCode   String  @map("employee_code")
  firstName      String  @map("first_name")
  lastName       String  @map("last_name")
  email          String
  phone          String?
  department     String?
  designation    String?
  joinDate       DateTime  @map("join_date")
  salary         Decimal  @db.Decimal(19, 4)
  bankAccount    String?  @map("bank_account")
  cnic           String?
  taxNumber      String?  @map("tax_number")
  isActive       Boolean  @default(true)  @map("is_active")
  createdAt      DateTime @default(now())  @map("created_at")
  updatedAt      DateTime @updatedAt  @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  salaries     SalaryRecord[]

  @@unique([organizationId, employeeCode])
  @@index([organizationId, isActive])
}

model SalaryRecord {
  id             String   @id @default(uuid())
  organizationId String  @map("organization_id")
  employeeId     String  @map("employee_id")
  month          Int
  year           Int
  basicSalary    Decimal  @db.Decimal(19, 4)  @map("basic_salary")
  allowances     Decimal  @db.Decimal(19, 4)
  bonuses        Decimal  @db.Decimal(19, 4)
  deductions     Decimal  @db.Decimal(19, 4)
  netSalary      Decimal  @db.Decimal(19, 4)  @map("net_salary")
  status         SalaryStatus @default(PENDING)
  paidAt         DateTime?  @map("paid_at")
  journalEntryId String?  @map("journal_entry_id")
  createdAt      DateTime @default(now())  @map("created_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  employee     Employee     @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([organizationId, employeeId, year, month])
  @@index([organizationId, status])
  @@index([employeeId])
}

enum SalaryStatus {
  PENDING
  PROCESSED
  PAID
  CANCELLED
}