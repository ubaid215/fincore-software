// prisma/schema/invoicing.prisma
// Domain: Invoicing & Billing
// Owner:  Invoicing team

model Invoice {
  id              String        @id @default(uuid())
  organizationId  String
  invoiceNumber   String
  clientName      String
  clientEmail     String?
  clientAddress   String?
  customerId      String?
  status          InvoiceStatus @default(DRAFT)
  issueDate       DateTime
  dueDate         DateTime?
  currency        String        @default("PKR")
  subtotal        Decimal       @db.Decimal(19, 4)
  taxAmount       Decimal       @default(0) @db.Decimal(19, 4)
  discountAmount  Decimal       @default(0) @db.Decimal(19, 4)
  totalAmount     Decimal       @db.Decimal(19, 4)
  amountPaid      Decimal       @default(0) @db.Decimal(19, 4)
  notes           String?
  pdfUrl          String?
  isRecurring     Boolean       @default(false)
  recurringPeriod String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  organization Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  customer     Contact?          @relation("CustomerInvoices", fields: [customerId], references: [id])
  lineItems    InvoiceLineItem[]
  payments     InvoicePayment[]

  @@unique([organizationId, invoiceNumber])
  @@index([organizationId, status])
  @@index([organizationId, dueDate])
  @@index([customerId])
}

// FIX: productId and product relation were already present in the schema file you sent.
// They are confirmed correct here. If you were getting "product does not exist on
// InvoiceLineItemInclude" errors, it means `prisma generate` had NOT been run after
// this relation was added. Running `npx prisma generate` will resolve those errors.
model InvoiceLineItem {
  id          String   @id @default(uuid())
  invoiceId   String
  description String
  quantity    Decimal  @db.Decimal(10, 4)
  unitPrice   Decimal  @db.Decimal(19, 4)
  taxCode     String?
  taxRate     Decimal  @default(0) @db.Decimal(5, 4)
  discount    Decimal  @default(0) @db.Decimal(5, 4)
  total       Decimal  @db.Decimal(19, 4)
  productId   String?

  invoice Invoice   @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  // FIX: This relation must exist for `include: { product: true }` to work in services.
  // If this was previously missing, add it and run `npx prisma generate && npx prisma migrate dev`.
  product Product?  @relation(fields: [productId], references: [id])

  @@index([invoiceId])
  @@index([productId])
}

model InvoicePayment {
  id        String   @id @default(uuid())
  invoiceId String
  amount    Decimal  @db.Decimal(19, 4)
  currency  String
  method    String
  reference String?
  paidAt    DateTime
  createdAt DateTime @default(now())

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
}

enum InvoiceStatus {
  DRAFT
  SENT
  PARTIALLY_PAID
  PAID
  VOID
  DISPUTED
}
