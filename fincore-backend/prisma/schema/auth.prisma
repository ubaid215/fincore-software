// prisma/schema/auth.prisma
// Domain: Authentication & Identity
// Owner:  Auth team
// Models: User, RefreshToken, Invite

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String  @map("password_hash")
  firstName    String  @map("first_name")
  lastName     String  @map("last_name")
  mfaEnabled   Boolean  @default(false)  @map("mfa_enabled")
  mfaSecret    String?  @map("mfa_secret")
  createdAt    DateTime @default(now())  @map("created_at")
  updatedAt    DateTime @updatedAt  @map("updated_at")

  organizations   UserOrganization[]     // → workspace.prisma
  refreshTokens   RefreshToken[]
  invitesSent     Invite[]               @relation("InviteSender")
  expensesClaimed Expense[]              @relation("ExpenseClaimer")  // → expenses.prisma
  expensesApproved Expense[]             @relation("ExpenseApprover") // → expenses.prisma
  paymentsConfirmed ManualPayment[]      @relation("PaymentConfirmer") // → manual-payments.prisma
}

model RefreshToken {
  id        String   @id @default(uuid())
  userId    String  @map("user_id")
  token     String   @unique
  expiresAt DateTime  @map("expires_at")
  createdAt DateTime @default(now())  @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
}

model Invite {
  id             String    @id @default(uuid())
  organizationId String  @map("organization_id")
  invitedById    String?  @map("invited_by_id")
  email          String
  role           UserRole
  token          String    @unique
  expiresAt      DateTime  @map("expires_at")
  acceptedAt     DateTime?  @map("accepted_at")
  createdAt      DateTime  @default(now())  @map("created_at")

  organization Organization @relation(fields: [organizationId], references: [id])  // → workspace.prisma
  invitedBy    User?        @relation("InviteSender", fields: [invitedById], references: [id])

  @@index([organizationId])
  @@index([token])
}

// ── Shared enums (referenced across multiple domain files) ────────────────────

enum UserRole {
  OWNER
  ADMIN
  ACCOUNTANT
  MANAGER
  VIEWER
}
