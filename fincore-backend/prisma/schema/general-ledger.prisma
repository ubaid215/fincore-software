// prisma/schema/general-ledger.prisma
// Domain: General Ledger
// Owner:  GL team

model JournalEntry {
  id             String             @id @default(uuid())
  organizationId String
  periodId       String?
  entryNumber    String
  description    String
  reference      String?
  entryDate      DateTime
  status         JournalEntryStatus @default(DRAFT)
  isReversed     Boolean            @default(false)
  reversalOfId   String?
  postedAt       DateTime?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  organization Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  period       FiscalPeriod? @relation(fields: [periodId], references: [id])
  lines        JournalLine[]
  reversalOf   JournalEntry? @relation("EntryReversal", fields: [reversalOfId], references: [id])
  reversals    JournalEntry[] @relation("EntryReversal")

  @@unique([organizationId, entryNumber])
  @@index([organizationId, status])
  @@index([organizationId, entryDate])
}

model JournalLine {
  id                 String   @id @default(uuid())
  journalEntryId     String
  accountId          String
  description        String?
  debit              Decimal  @default(0) @db.Decimal(19, 4)
  credit             Decimal  @default(0) @db.Decimal(19, 4)
  currency           String   @default("PKR")
  fxRate             Decimal  @default(1) @db.Decimal(19, 6)
  baseCurrencyDebit  Decimal  @default(0) @db.Decimal(19, 4)
  baseCurrencyCredit Decimal  @default(0) @db.Decimal(19, 4)
  createdAt          DateTime @default(now())

  journalEntry JournalEntry @relation(fields: [journalEntryId], references: [id], onDelete: Cascade)
  account      Account      @relation(fields: [accountId], references: [id])

  @@index([journalEntryId])
  @@index([accountId])
}

enum JournalEntryStatus {
  DRAFT
  POSTED
  REVERSED
}