// prisma/schema/audit.prisma
// Domain: Audit Logging (cross-cutting)
// Owner:  Lead / DevOps
// Models: AuditLog
//
// Written to for every significant state change across all domains.
// Tagged with organizationId for multi-tenant isolation.
// Append-only — no updates or deletes.

model AuditLog {
  id             String   @id @default(uuid())
  organizationId String  @map("organization_id")
  userId         String?  @map("user_id")
  action         String   // e.g. "invoice.sent", "expense.approved", "payment.confirmed"
  resourceType   String   // e.g. "Invoice", "Expense", "ManualPayment"  @map("resource_type")
  resourceId     String  @map("resource_id")
  metadata       Json?    // Any extra context — old/new state, amounts, etc.
  ipAddress      String?  @map("ip_address")
  userAgent      String?  @map("user_agent")
  createdAt      DateTime @default(now())  @map("created_at")

  organization Organization @relation(fields: [organizationId], references: [id])

  @@index([organizationId, resourceType, resourceId])
  @@index([organizationId, action])
  @@index([organizationId, createdAt])
}
