{{! payment-rejected.hbs }}
<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8">
  <title>FinCore Payment Update</title>
  <style>
    body { font-family: Arial, sans-serif; line-height: 1.6; color: #333; max-width: 600px; margin: 0 auto; padding: 20px; }
    .header { background: #dc2626; color: white; padding: 20px; text-align: center; border-radius: 8px 8px 0 0; }
    .content { background: #f9fafb; padding: 30px; border: 1px solid #e5e7eb; border-top: none; border-radius: 0 0 8px 8px; }
    .footer { margin-top: 30px; text-align: center; font-size: 12px; color: #6b7280; }
  </style>
</head>
<body>
  <div class="header">
    <h1>Payment Update</h1>
  </div>
  <div class="content">
    <p>Dear {{customerName}},</p>

    <p>Your payment with reference code <strong>{{referenceCode}}</strong> could not be approved.</p>

    <p><strong>Reason:</strong> {{rejectionReason}}</p>

    <p>If you have already made the transfer, please contact our support team with your bank transaction receipt.</p>

    <p>To retry, please initiate a new payment from the FinCore dashboard.</p>

    <p>Need assistance? Email us at <a href="mailto:{{supportEmail}}">{{supportEmail}}</a></p>
  </div>
  <div class="footer">
    <p>&copy; {{formatYear}} FinCore. All rights reserved.</p>
  </div>
</body>
</html>