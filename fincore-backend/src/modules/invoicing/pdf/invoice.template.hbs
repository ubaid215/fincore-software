<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Invoice {{invoiceNumber}}</title>
<style>
  /* ── Reset ─────────────────────────────────────────────────────────────── */
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  /* ── Base ──────────────────────────────────────────────────────────────── */
  html, body {
    font-family: -apple-system, 'Segoe UI', 'Helvetica Neue', Arial, sans-serif;
    font-size: 11pt;
    color: #1a1916;
    background: #ffffff;
    line-height: 1.5;
    -webkit-print-color-adjust: exact;
    print-color-adjust: exact;
  }

  /* ── Page layout ───────────────────────────────────────────────────────── */
  .page {
    width: 210mm;
    min-height: 297mm;
    padding: 14mm 16mm 16mm;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
  }

  /* ── Header ────────────────────────────────────────────────────────────── */
  .header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    padding-bottom: 10mm;
    border-bottom: 2px solid #2A7D6F;
    margin-bottom: 8mm;
  }

  .org-block { flex: 1; }

  .org-logo {
    max-height: 48px;
    max-width: 160px;
    object-fit: contain;
    margin-bottom: 6px;
    display: block;
  }

  .org-name {
    font-size: 15pt;
    font-weight: 700;
    color: #1a1916;
    letter-spacing: -0.02em;
    margin-bottom: 2px;
  }

  .org-meta {
    font-size: 8.5pt;
    color: #79766F;
    line-height: 1.6;
  }

  .invoice-meta-block {
    text-align: right;
    min-width: 140px;
  }

  .invoice-title {
    font-size: 22pt;
    font-weight: 700;
    color: #2A7D6F;
    letter-spacing: -0.03em;
    line-height: 1;
    margin-bottom: 6px;
  }

  .invoice-number {
    font-family: 'Courier New', monospace;
    font-size: 10pt;
    font-weight: 600;
    color: #1a1916;
    background: #F5F4F2;
    padding: 3px 8px;
    border-radius: 4px;
    display: inline-block;
    margin-bottom: 8px;
  }

  /* Status badge */
  .status-badge {
    display: inline-block;
    padding: 3px 10px;
    border-radius: 100px;
    font-size: 7.5pt;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }
  .status-DRAFT         { background: #F1EFE8; color: #5F5C55; }
  .status-SENT          { background: #E8F1F8; color: #174E78; }
  .status-VIEWED        { background: #EAF4F2; color: #1C5448; }
  .status-PARTIALLY_PAID { background: #FDF5E4; color: #7A5508; }
  .status-PAID          { background: #EAF3EE; color: #1F5C33; }
  .status-OVERDUE       { background: #FBEAEA; color: #952626; }
  .status-VOID          { background: #F1EFE8; color: #A8A49E; }
  .status-DISPUTED      { background: #FBEAEA; color: #952626; }

  /* ── Parties ───────────────────────────────────────────────────────────── */
  .parties {
    display: flex;
    gap: 12mm;
    margin-bottom: 8mm;
  }

  .party { flex: 1; }

  .party-label {
    font-size: 7pt;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #A8A49E;
    margin-bottom: 4px;
  }

  .party-name {
    font-size: 11pt;
    font-weight: 700;
    color: #1a1916;
    margin-bottom: 2px;
  }

  .party-detail {
    font-size: 8.5pt;
    color: #79766F;
    line-height: 1.6;
  }

  /* ── Dates strip ───────────────────────────────────────────────────────── */
  .dates-strip {
    display: flex;
    gap: 6mm;
    background: #F5F4F2;
    border-radius: 6px;
    padding: 5mm 6mm;
    margin-bottom: 8mm;
  }

  .date-item { flex: 1; }

  .date-label {
    font-size: 7pt;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #A8A49E;
    margin-bottom: 2px;
  }

  .date-value {
    font-size: 9.5pt;
    font-weight: 600;
    color: #1a1916;
  }

  .date-value.overdue {
    color: #B83030;
  }

  /* ── References ─────────────────────────────────────────────────────────── */
  .references {
    display: flex;
    gap: 6mm;
    margin-bottom: 7mm;
  }

  .ref-item {
    font-size: 8pt;
    color: #79766F;
  }

  .ref-item strong {
    color: #4A4844;
  }

  /* ── Line items table ──────────────────────────────────────────────────── */
  .line-items-table {
    width: 100%;
    border-collapse: collapse;
    margin-bottom: 6mm;
    font-size: 8.5pt;
  }

  .line-items-table thead tr {
    border-bottom: 1.5px solid #1a1916;
  }

  .line-items-table th {
    padding: 4px 6px 6px;
    font-size: 7pt;
    font-weight: 700;
    letter-spacing: 0.07em;
    text-transform: uppercase;
    color: #79766F;
    text-align: left;
  }

  .line-items-table th.r { text-align: right; }

  .line-items-table tbody tr {
    border-bottom: 1px solid #E4E2DE;
  }

  .line-items-table tbody tr:last-child { border-bottom: none; }

  .line-items-table td {
    padding: 5px 6px;
    vertical-align: top;
    color: #1a1916;
  }

  .line-items-table td.r { text-align: right; font-family: 'Courier New', monospace; }

  .line-items-table td.desc { max-width: 80mm; }

  .line-num {
    color: #A8A49E;
    font-size: 7.5pt;
    font-weight: 600;
    width: 16px;
    text-align: center;
  }

  .tax-badge {
    display: inline-block;
    background: #F5F4F2;
    color: #79766F;
    font-size: 7pt;
    padding: 1px 4px;
    border-radius: 3px;
    margin-top: 1px;
  }

  /* ── Totals ────────────────────────────────────────────────────────────── */
  .totals-section {
    display: flex;
    justify-content: flex-end;
    margin-bottom: 8mm;
  }

  .totals-table {
    width: 72mm;
  }

  .totals-row {
    display: flex;
    justify-content: space-between;
    padding: 2.5px 0;
    font-size: 8.5pt;
    color: #4A4844;
  }

  .totals-row.subtotal-row { color: #79766F; }

  .totals-row.total-row {
    border-top: 1.5px solid #1a1916;
    margin-top: 4px;
    padding-top: 5px;
    font-size: 11pt;
    font-weight: 700;
    color: #1a1916;
  }

  .totals-row.paid-row { color: #2D7D46; }

  .totals-row.balance-row {
    border-top: 1.5px solid #1a1916;
    margin-top: 4px;
    padding-top: 5px;
    font-size: 12pt;
    font-weight: 700;
    color: #2A7D6F;
  }

  .mono { font-family: 'Courier New', monospace; }

  /* ── Paid stamp ────────────────────────────────────────────────────────── */
  .paid-stamp {
    position: relative;
  }

  .paid-stamp::after {
    content: 'PAID';
    position: absolute;
    top: -28mm;
    right: 0;
    font-size: 36pt;
    font-weight: 900;
    color: rgba(45, 125, 70, 0.12);
    letter-spacing: 0.08em;
    border: 4px solid rgba(45, 125, 70, 0.12);
    padding: 4px 14px;
    border-radius: 6px;
    transform: rotate(-12deg);
    pointer-events: none;
  }

  /* ── Notes & Terms ─────────────────────────────────────────────────────── */
  .notes-section {
    margin-top: auto;
    padding-top: 6mm;
    border-top: 1px solid #E4E2DE;
    display: flex;
    gap: 10mm;
  }

  .notes-block { flex: 1; }

  .notes-label {
    font-size: 7pt;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #A8A49E;
    margin-bottom: 3px;
  }

  .notes-body {
    font-size: 8pt;
    color: #79766F;
    line-height: 1.5;
    white-space: pre-wrap;
  }

  /* ── Footer ────────────────────────────────────────────────────────────── */
  .footer {
    margin-top: 6mm;
    padding-top: 4mm;
    border-top: 1px solid #E4E2DE;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .footer-left { font-size: 7pt; color: #A8A49E; }
  .footer-right { font-size: 7pt; color: #A8A49E; text-align: right; }
  .footer-brand { color: #2A7D6F; font-weight: 600; }

  /* ── Print ─────────────────────────────────────────────────────────────── */
  @media print {
    body { margin: 0; }
    .page { padding: 14mm 16mm 16mm; }
  }
</style>
</head>
<body>
<div class="page">

  <!-- ── Header ─────────────────────────────────────────────────────────── -->
  <div class="header">
    <div class="org-block">
      {{#if org.logoUrl}}
      <img src="{{org.logoUrl}}" alt="{{org.name}}" class="org-logo" />
      {{else}}
      <div class="org-name">{{org.name}}</div>
      {{/if}}
      <div class="org-meta">
        {{#if org.email}}<div>{{org.email}}</div>{{/if}}
        {{#if org.phone}}<div>{{org.phone}}</div>{{/if}}
        {{#if org.website}}<div>{{org.website}}</div>{{/if}}
        {{#if org.address}}<div>{{org.address}}</div>{{/if}}
      </div>
    </div>
    <div class="invoice-meta-block">
      <div class="invoice-title">INVOICE</div>
      <div class="invoice-number">{{invoiceNumber}}</div>
      <div>
        <span class="status-badge status-{{status}}">{{status}}</span>
      </div>
    </div>
  </div>

  <!-- ── Parties ────────────────────────────────────────────────────────── -->
  <div class="parties">
    <div class="party">
      <div class="party-label">Bill To</div>
      <div class="party-name">{{customer.name}}</div>
      <div class="party-detail">
        {{#if customer.email}}<div>{{customer.email}}</div>{{/if}}
        {{#if customer.phone}}<div>{{customer.phone}}</div>{{/if}}
        {{#if customer.address}}<div>{{customer.address}}</div>{{/if}}
        {{#if customer.taxId}}<div>NTN: {{customer.taxId}}</div>{{/if}}
      </div>
    </div>
    <div class="party">
      <div class="party-label">Issued By</div>
      <div class="party-name">{{org.name}}</div>
      <div class="party-detail">
        {{#if org.email}}<div>{{org.email}}</div>{{/if}}
        {{#if org.phone}}<div>{{org.phone}}</div>{{/if}}
      </div>
    </div>
  </div>

  <!-- ── Dates ──────────────────────────────────────────────────────────── -->
  <div class="dates-strip">
    <div class="date-item">
      <div class="date-label">Issue Date</div>
      <div class="date-value">{{issueDate}}</div>
    </div>
    {{#if dueDate}}
    <div class="date-item">
      <div class="date-label">Due Date</div>
      <div class="date-value{{#if isOverdue}} overdue{{/if}}">
        {{dueDate}}{{#if isOverdue}} — OVERDUE{{/if}}
      </div>
    </div>
    {{/if}}
    <div class="date-item">
      <div class="date-label">Currency</div>
      <div class="date-value">{{currency}}</div>
    </div>
  </div>

  <!-- ── References ────────────────────────────────────────────────────── -->
  {{#if (or purchaseOrder reference)}}
  <div class="references">
    {{#if purchaseOrder}}
    <div class="ref-item"><strong>PO Reference:</strong> {{purchaseOrder}}</div>
    {{/if}}
    {{#if reference}}
    <div class="ref-item"><strong>Reference:</strong> {{reference}}</div>
    {{/if}}
  </div>
  {{/if}}

  <!-- ── Line items ─────────────────────────────────────────────────────── -->
  <table class="line-items-table">
    <thead>
      <tr>
        <th style="width:16px">#</th>
        <th>Description</th>
        <th class="r" style="width:42px">Qty</th>
        <th class="r" style="width:52px">Unit Price</th>
        {{#if hasDiscount}}<th class="r" style="width:42px">Disc.</th>{{/if}}
        {{#if hasTax}}<th class="r" style="width:38px">Tax</th>{{/if}}
        <th class="r" style="width:56px">Amount</th>
      </tr>
    </thead>
    <tbody>
      {{#each lineItems}}
      <tr>
        <td class="line-num">{{this.index}}</td>
        <td class="desc">
          <div>{{this.description}}</div>
          {{#if this.taxCode}}<span class="tax-badge">{{this.taxCode}}</span>{{/if}}
        </td>
        <td class="r">{{formatNumber this.quantity}}</td>
        <td class="r mono">{{formatMoney this.unitPrice}}</td>
        {{#if ../hasDiscount}}<td class="r">{{formatPercent this.discount}}</td>{{/if}}
        {{#if ../hasTax}}<td class="r">{{formatPercent this.taxRate}}</td>{{/if}}
        <td class="r mono"><strong>{{formatMoney this.total}}</strong></td>
      </tr>
      {{/each}}
    </tbody>
  </table>

  <!-- ── Totals ─────────────────────────────────────────────────────────── -->
  <div class="totals-section{{#if (eq status 'PAID')}} paid-stamp{{/if}}">
    <div class="totals-table">
      <div class="totals-row subtotal-row">
        <span>Subtotal</span>
        <span class="mono">{{currency}} {{formatMoney subtotal}}</span>
      </div>
      {{#if hasDiscount}}
      <div class="totals-row subtotal-row">
        <span>Discount</span>
        <span class="mono" style="color:#B83030">− {{currency}} {{formatMoney discountAmount}}</span>
      </div>
      {{/if}}
      {{#if hasTax}}
      <div class="totals-row subtotal-row">
        <span>Tax</span>
        <span class="mono">+ {{currency}} {{formatMoney taxAmount}}</span>
      </div>
      {{/if}}
      <div class="totals-row total-row">
        <span>Total</span>
        <span class="mono">{{currency}} {{formatMoney totalAmount}}</span>
      </div>
      {{#if hasPaid}}
      <div class="totals-row paid-row">
        <span>Amount Paid</span>
        <span class="mono">− {{currency}} {{formatMoney amountPaid}}</span>
      </div>
      <div class="totals-row balance-row">
        <span>Balance Due</span>
        <span class="mono">{{currency}} {{formatMoney balanceDue}}</span>
      </div>
      {{/if}}
    </div>
  </div>

  <!-- ── Notes & Terms ──────────────────────────────────────────────────── -->
  {{#if (or notes terms)}}
  <div class="notes-section">
    {{#if terms}}
    <div class="notes-block">
      <div class="notes-label">Payment Terms</div>
      <div class="notes-body">{{terms}}</div>
    </div>
    {{/if}}
    {{#if notes}}
    <div class="notes-block">
      <div class="notes-label">Notes</div>
      <div class="notes-body">{{notes}}</div>
    </div>
    {{/if}}
  </div>
  {{/if}}

  <!-- ── Footer ─────────────────────────────────────────────────────────── -->
  <div class="footer">
    <div class="footer-left">
      Generated {{generatedAt}} · <span class="footer-brand">FinCore</span>
    </div>
    <div class="footer-right">
      {{invoiceNumber}}{{#if purchaseOrder}} · PO: {{purchaseOrder}}{{/if}}
    </div>
  </div>

</div>
</body>
</html>
